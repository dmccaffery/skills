root = true

[*]
indent_style = space
indent_size = 4
char_set = utf-8
insert_final_newline = true
max_line_length = 120

[*.{js,json}]
indent_size = 2

[*.md]
indent_size = 4

[Makefile]
indent_style = tab

[*.config]
indent_style = tab

[*.sh]
indent_style = tab
language_dialect = posix
space_redirects = true
